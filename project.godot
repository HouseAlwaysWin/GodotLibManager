; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GodotLibManager"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[dotnet]

project/assembly_name="GodotLibManager"
external_debug_attach/ide_type=0
external_debug_attach/vscode_path=""
external_debug_attach/cursor_path=""
external_debug_attach/antigravity_path=""
external_debug_attach/show_service_console=false
external_debug_attach/auto_register_debugwait_autoload=true
external_debug_attach/debug_wait_seconds=12.0
external_debug_attach/f5_attach_check_max=12

[editor_plugins]

enabled=PackedStringArray("res://addons/external_debug_attach/plugin.cfg", "res://addons/godot_lib_manager/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
